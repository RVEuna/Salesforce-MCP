# =============================================================================
# Terraform Variables Example
# Copy this to terraform.tfvars and fill in your values
# =============================================================================

# Required
project_name = "salesforce-mcp-server"

# Optional - uncomment to customize
# aws_region   = "us-east-2"
# environment  = "dev"
# alarm_email  = "alerts@example.com"

# Lambda deployment (provide either a local zip path or S3 location)
# lambda_zip_path  = "../../lambda.zip"
# lambda_s3_bucket = "my-deployment-bucket"
# lambda_s3_key    = "salesforce-mcp-server/lambda.zip"

# All Salesforce/MCP credentials are managed in Secrets Manager via the Console.
# See README.md for the required secret keys.

# Additional tags
# tags = {
#   Team       = "platform"
#   CostCenter = "engineering"
# }
