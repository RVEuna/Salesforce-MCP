# AWS deployment configuration
# Copy this to .env for AWS deployment

# Salesforce (Connected App)
SALESFORCE_INSTANCE_URL=https://myorg.my.salesforce.com
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_CLIENT_ID=<Connected App consumer key>
SALESFORCE_CLIENT_SECRET=<Connected App consumer secret>
SALESFORCE_API_VERSION=v66.0

# MCP Server
MCP_SERVER_NAME=salesforce-mcp-server
MCP_SERVER_VERSION=1.0.0
MCP_LOG_LEVEL=INFO
MCP_LOG_FORMAT=json
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp
MCP_STATELESS=true
MCP_SECRET_PROVIDER=aws
MCP_AWS_SECRET_NAME=mcp/api-keys
MCP_AWS_SECRET_REGION=us-east-2
