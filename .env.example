# AWS deployment configuration
# Copy this to .env for AWS deployment
#
# Sensitive values (Salesforce credentials, JWT secret, etc.) are stored
# in AWS Secrets Manager and loaded at startup. See MCP_AWS_SECRET_NAME.

# MCP Server
MCP_SERVER_NAME=salesforce-mcp-server
MCP_SERVER_VERSION=1.0.0
MCP_LOG_LEVEL=INFO
MCP_LOG_FORMAT=json
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp
MCP_STATELESS=true
MCP_SECRET_PROVIDER=aws
MCP_AWS_SECRET_NAME=mcp/salesforce-mcp-server/api-keys
MCP_AWS_SECRET_REGION=us-east-2
