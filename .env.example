# AWS deployment configuration
# Copy this to .env for AWS deployment

# OpenSearch (AWS managed domain)
OPENSEARCH_ENDPOINT=https://search-my-domain.us-east-2.es.amazonaws.com
OPENSEARCH_INDEX=documents
OPENSEARCH_REGION=us-east-2
OPENSEARCH_SERVICE=es
OPENSEARCH_AUTH_MODE=aws

# MCP Server
MCP_SERVER_NAME=my-mcp-server
MCP_SERVER_VERSION=1.0.0
MCP_LOG_LEVEL=INFO
MCP_LOG_FORMAT=json
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp
MCP_STATELESS=true
MCP_SECRET_PROVIDER=aws
MCP_AWS_SECRET_NAME=mcp/api-keys
MCP_AWS_SECRET_REGION=us-east-2
