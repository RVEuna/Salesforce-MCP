# Local development configuration
# Copy this to .env for local development with Docker OpenSearch

# OpenSearch (local Docker)
OPENSEARCH_ENDPOINT=http://localhost:9200
OPENSEARCH_INDEX=documents
OPENSEARCH_AUTH_MODE=none

# MCP Server
MCP_SERVER_NAME=my-mcp-server
MCP_SERVER_VERSION=1.0.0
MCP_LOG_LEVEL=DEBUG
MCP_LOG_FORMAT=text
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp
MCP_STATELESS=true
MCP_SECRET_PROVIDER=local
