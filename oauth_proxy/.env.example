# Salesforce OAuth Proxy — environment variables
# Copy to .env.proxy for local proxy development

# Salesforce Connected App (same credentials as the MCP server)
SALESFORCE_CLIENT_ID=<Connected App consumer key>
SALESFORCE_CLIENT_SECRET=<Connected App consumer secret>
SALESFORCE_LOGIN_URL=https://test.salesforce.com

# Where to forward authenticated /mcp requests
# Local dev: point at the MCP server running on localhost
AGENTCORE_URL=http://localhost:8000/mcp
# Production: use the AgentCore invocation URL
# AGENTCORE_URL=https://<runtime-id>.runtime.agentcore.<region>.amazonaws.com/mcp

# Secret for encrypting short-lived auth codes during the OAuth dance.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
PROXY_SECRET=<random-hex-string>

# Optional overrides
# PROXY_BASE_URL=https://<lambda-function-url>
# PROXY_PORT=9090
# LOG_LEVEL=DEBUG
# UPSTREAM_TIMEOUT=120
# SF_ACCESS_TOKEN_TTL=7200
# AUTH_CODE_TTL=300
